# Backend
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/stratix?schema=public
JWT_SECRET=replace-with-a-secure-random-secret
JWT_EXPIRES_IN=1d
FRONTEND_URL=http://localhost:5173
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM=no-reply@example.com
EMAIL_DEMO_MODE=false
MONGO_URL=mongodb://localhost:27017
MONGO_DB=stratix_logs
POSTGRES_DB=stratix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Alternate Mongo aliases accepted by the API
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=stratix_logs
# Optional / reserved for future integrations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
