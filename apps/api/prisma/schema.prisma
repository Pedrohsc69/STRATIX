generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DIRECTOR
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum CycleStatus {
  ACTIVE
  CLOSED
}

enum OKRMetricType {
  PERCENTAGE
  NUMBER
  CURRENCY
  BOOLEAN
}

enum ObjectivePriority {
  HIGH
  MEDIUM
  LOW
  UNSPECIFIED
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  hasUsablePassword Boolean @default(true)
  role     UserRole
  status   UserStatus @default(PENDING)

  isActive Boolean @default(false)
  avatarUrl String?
  lastAccessAt DateTime?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  departmentId String?
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id])

  managedDepartments Department[] @relation("DepartmentManager")

  okrs OKR[]
  passwordResetTokens PasswordResetToken[]
  settings UserSettings?
  progressUpdates ProgressOKR[] @relation("ProgressActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invite {
  id        String @id @default(uuid())

  email     String  @unique
  role UserRole

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  token String @unique

  expiresAt DateTime
  accepted  Boolean @default(false)

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model UserSettings {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  theme ThemePreference @default(SYSTEM)
  language String @default("pt-BR")

  emailNotifications Boolean @default(true)
  inviteNotifications Boolean @default(true)
  okrNotifications Boolean @default(true)
  cycleNotifications Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        String @id @default(uuid())
  name      String
  cnpj      String @unique
  businessArea String

  users       User[]
  departments Department[]
  invites Invite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String @id @default(uuid())
  name      String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  users User[] @relation("UserDepartment")

  invites Invite[]

  managerId String?
  manager   User? @relation("DepartmentManager", fields: [managerId], references: [id])

  cycles StrategicCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StrategicCycle {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    CycleStatus

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  objectives Objective[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Objective {
  id          String @id @default(uuid())
  name        String
  description String
  priority    ObjectivePriority @default(UNSPECIFIED)

  cycleId String
  cycle   StrategicCycle @relation(fields: [cycleId], references: [id])

  okrs OKR[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OKR {
  id          String  @id @default(uuid())
  name        String
  metricType  OKRMetricType @default(NUMBER)
  targetValue Float
  currentValue Float

  objectiveId String
  objective   Objective @relation(fields: [objectiveId], references: [id])

  responsibleId String
  responsible   User @relation(fields: [responsibleId], references: [id])

  progress ProgressOKR[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProgressOKR {
  id        String   @id @default(uuid())
  value     Float
  date      DateTime
  comment   String

  okrId String
  okr   OKR @relation(fields: [okrId], references: [id])

  actorId String?
  actor   User?   @relation("ProgressActor", fields: [actorId], references: [id])

  createdAt DateTime @default(now())
}
