generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRETOR
  GESTOR
  COLABORADOR
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  name         String
  passwordHash String
  role         Role
  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id])
  memberships  DepartmentMember[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Company {
  id          String       @id @default(uuid())
  name        String
  departments Department[]
  users       User[]
  cycles      Cycle[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id          String             @id @default(uuid())
  name        String
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id])
  objectives  Objective[]
  memberships DepartmentMember[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model DepartmentMember {
  id           String     @id @default(uuid())
  departmentId String
  userId       String
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([departmentId, userId])
}

model Cycle {
  id         String      @id @default(uuid())
  name       String
  startsAt   DateTime
  endsAt     DateTime
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  objectives Objective[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Objective {
  id           String      @id @default(uuid())
  title        String
  description  String?
  cycleId      String
  departmentId String
  cycle        Cycle       @relation(fields: [cycleId], references: [id])
  department   Department  @relation(fields: [departmentId], references: [id])
  okrs         Okr[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Okr {
  id          String   @id @default(uuid())
  title       String
  metric      String
  current     Float    @default(0)
  target      Float
  objectiveId String
  objective   Objective @relation(fields: [objectiveId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
